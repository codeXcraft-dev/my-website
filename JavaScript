function toggleDarkMode() {
  let body = document.body;
  body.classList.toggle("dark");

  let btn = document.querySelector("header .btn");
  if (body.classList.contains("dark")) {
    btn.innerHTML = "☀️ Light Mode";
  } else {
    btn.innerHTML = "🌙 Dark Mode";
  }
}